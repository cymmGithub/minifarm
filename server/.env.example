NODE_ENV=develop
PORT=3801
PATH_TO_PLAYWRIGHT=../playwright
PATH_TO_REPORTS=/home/user/playwright-reports
PATH_TO_PIPELINE_FILE=/home/user/pipeline_runs.json
TEST_QUEUE_FILE=/home/user/test_queue.json
CLIENTS_FILE=./clients.json

# Test timeout in seconds
TEST_TIMEOUT=600
# Ping timeout in milliseconds
PING_TIMEOUT=100

# Pipeline executor - path to minifarm directory
MINIFARM_DIR=/opt/code/devops/minifarm

# Grep-invert pattern to exclude tests (regex, use | for multiple patterns)
TEST_GREP_INVERT_PATTERN="^mobile/|new-season/"
